{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(ls *)",
            "Bash(find *)",
            "Bash(cat *)",
            "Bash(grep *)",
            "Bash(wc *)",
            "Bash(head *)",
            "Bash(tail *)",
            "Bash(jq *)",
            "Bash(git log *)",
            "Bash(git diff *)",
            "Bash(git status)",
            "Bash(git show *)",
            "Bash(git branch *)",
            "Bash(git remote *)",
            "Bash(echo *)",
            "Bash(pwd)",
            "Bash(which *)",
            "Bash(diff *)",
            "Bash(sort *)",
            "Bash(uniq *)",
            "Bash(awk *)",
            "Bash(cut *)",
            "Bash(tr *)",
            "Bash(brew list *)",
            "Bash(brew info *)",
            "Bash(docker logs *)",
            "Bash(docker stats *)",
            "Bash(docker ps *)",
            "Bash(docker images *)",
            "Bash(docker inspect *)",
            "Bash(docker network ls)",
            "Bash(docker volume ls)",
            "Bash(docker compose ps *)",
            "Bash(~/.claude/scripts/*)",
            "Read(*)",
            "Edit(~/Documents/GitHub/dev_setup/.claude/**)",
            "Write(~/Documents/GitHub/dev_setup/.claude/**)"
        ]
    },
  "model": "opusplan",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "python3 ~/Documents/GitHub/dev_setup/.claude/scripts/block-destructive-commands.py"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash ~/.claude/statusline.sh"
    },
    "enabledPlugins": {
        "caveman@caveman": true,
        "ponytail@ponytail": true
    },
    "extraKnownMarketplaces": {
        "caveman": {
            "source": {
                "source": "github",
                "repo": "JuliusBrussee/caveman"
            }
        },
        "ponytail": {
            "source": {
                "source": "github",
                "repo": "DietrichGebert/ponytail"
            }
        }
    },
  "skipAutoPermissionPrompt": false
}
