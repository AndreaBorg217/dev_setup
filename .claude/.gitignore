!commands/**
!hooks/
!hooks/**
hooks/__pycache__/
hooks/**/*.py[cod]
!output-styles/
!output-styles/**
!scripts/
!scripts/**
!themes/
!themes/**
!workflows/
!workflows/**
!statusline.sh
