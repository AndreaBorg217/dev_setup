{
    // Aesthetics
    "workbench.colorTheme": "Tokyo Night",
    "workbench.iconTheme": "material-icon-theme",
    "editor.fontSize": 18,
    "window.zoomLevel": 2,
    // Disable updates & telemetry
    "update.mode": "none",
    "extensions.autoUpdate": false,
    "telemetry.telemetryLevel": "off",
    "workbench.enableExperiments": false,
    // Strip UI
    "editor.minimap.enabled": false,
    "workbench.sideBar.location": "left",
    "breadcrumbs.enabled": false, // path breadcrumbs above editor
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    "editor.autoSurround": "never",
    "window.commandCenter": true, // search at the top
    "workbench.activityBar.location": "default",
    "workbench.navigationControl.enabled": false, // arrows next to search
    "workbench.layoutControl.enabled": false, // buttons to toggle panels etc top right
    "workbench.startupEditor": "none",
    // AI
    "chat.disableAIFeatures": true,
    "coderabbit.agentType": "Claude Code",
    "coderabbit.autoReviewMode": "disabled",
    "coderabbit.region": "eu",
    "coderabbit.autoStartTask": false,
    "editor.inlineSuggest.minShowDelay": 500,
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "on"
    },
    // Formatting and LSP
    "files.autoSave": "off",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    // Include gitignored files in search / quick open
    "search.useIgnoreFiles": false,
    // PYTHON Configuration
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        },
    },
    "python.analysis.typeCheckingMode": "standard",
    // GO Configuration
    "[go]": {
        "editor.defaultFormatter": "golang.go",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit",
        },
    },
    "go.useLanguageServer": true,
    "go.lintOnSave": "package",
    "go.lintTool": "golangci-lint",
    "gopls": {
        "formatting.gofumpt": true
    },
    // JAVASCRIPT/TYPESCRIPT/REACT Configuration
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "prettier.tabWidth": 4,
    "prettier.useTabs": false,
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    // VIM
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<Esc>"
            ],
            "commands": [
                ":nohl"
            ], // Clears highlight of current search
            "silent": true,
        },
        {
            // - to go to end of text
            "before": [
                "-"
            ],
            "after": [
                "$"
            ],
        },
        {
            // ` to go to start of text
            "before": [
                "`"
            ],
            "after": [
                "^"
            ],
        },
        {
            // R to redo
            "before": [
                "R"
            ],
            "after": [
                "<C-r>"
            ],
        },
        {
            "before": [
                "s" // like flash.nvim
            ],
            "after": [
                "<leader>",
                "<leader>",
                "s"
            ],
        },
    ],
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false,
    },
    "vim.incsearch": true,
    "vim.searchHighlightTextColor": "#FF0000",
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.color": "#F55D40",
    "vim.highlightedyank.duration": 200,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.smartRelativeLine": true,
    "vim.surround": true,
    "vim.easymotion": true,
    "vim.showMarksInGutter": true,
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1, // GREATLY improves vim performance
    },
    // GITLENS Configuration
    "gitlens.currentLine.enabled": false,
    "gitlens.codeLens.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": false,
        "tags": false,
        "worktrees": true,
        "contributors": true,
        "repositories": true,
        "searchAndCompare": true,
        "launchpad": true,
    },
    "cSpell.diagnosticLevel": "Hint",
    "hediet.vscode-drawio.resizeImages": null,
}
